{
  "name": "composio-ao-plugin",
  "version": "0.3.1",
  "description": "OpenClaw plugin for CAHI — AI tools, slash commands, hooks, and health monitoring for managing parallel coding agents from OpenClaw",
  "license": "MIT",
  "author": "Dhruv Sharma (https://github.com/illegalcall)",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
