    "directory": "openclaw-plugin"
  },
  "homepage": "https://github.com/contaazul/cahi/tree/main/openclaw-plugin",
  "bugs": "https://github.com/contaazul/cahi/issues",
  "keywords": ["openclaw", "openclaw-plugin", "plugin", "cahi", "composio", "ai-agents", "coding-agents"],
  "publishConfig": {
