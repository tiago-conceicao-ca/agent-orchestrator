{
  "name": "@contaazul/cahi-cli",
  "version": "0.9.2",
  "description": "CLI for cahi — the `ao` command",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cahi": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/contaazul/cahi.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/contaazul/cahi",
  "bugs": {
    "url": "https://github.com/contaazul/cahi/issues"
  },
  "engines": {
    "node": ">=20.18.3"
  },
  "scripts": {
    "build": "tsc && node --input-type=commonjs -e \"require('fs').cpSync('src/assets','dist/assets',{recursive:true})\"",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contaazul/cahi-core": "workspace:*",
    "@contaazul/cahi-notifier-macos": "workspace:*",
    "@contaazul/cahi-plugin-agent-aider": "workspace:*",
    "@contaazul/cahi-plugin-agent-claude-code": "workspace:*",
    "@contaazul/cahi-plugin-agent-codex": "workspace:*",
    "@contaazul/cahi-plugin-agent-cursor": "workspace:*",
    "@contaazul/cahi-plugin-agent-grok": "workspace:*",
    "@contaazul/cahi-plugin-agent-kimicode": "workspace:*",
    "@contaazul/cahi-plugin-agent-opencode": "workspace:*",
    "@contaazul/cahi-plugin-notifier-composio": "workspace:*",
    "@contaazul/cahi-plugin-notifier-dashboard": "workspace:*",
    "@contaazul/cahi-plugin-notifier-desktop": "workspace:*",
    "@contaazul/cahi-plugin-notifier-discord": "workspace:*",
    "@contaazul/cahi-plugin-notifier-slack": "workspace:*",
    "@contaazul/cahi-plugin-notifier-webhook": "workspace:*",
    "@contaazul/cahi-plugin-runtime-process": "workspace:*",
    "@contaazul/cahi-plugin-runtime-tmux": "workspace:*",
    "@contaazul/cahi-plugin-scm-github": "workspace:*",
    "@contaazul/cahi-plugin-terminal-iterm2": "workspace:*",
    "@contaazul/cahi-plugin-terminal-web": "workspace:*",
    "@contaazul/cahi-plugin-tracker-github": "workspace:*",
    "@contaazul/cahi-plugin-tracker-linear": "workspace:*",
    "@contaazul/cahi-plugin-workspace-clone": "workspace:*",
    "@contaazul/cahi-plugin-workspace-worktree": "workspace:*",
    "@contaazul/cahi-sdlc": "workspace:*",
    "@contaazul/cahi-web": "workspace:*",
    "@clack/prompts": "^0.9.1",
    "@composio/core": "^0.9.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ora": "^8.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
